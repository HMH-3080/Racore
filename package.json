{
  "name": "racore-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["packages/cli"],
  "scripts": {
    "dev:cli": "bun run --watch packages/cli/src/index.tsx",
    "build:cli": "bun run --filter racore build",
    "link:cli": "bun run build:cli && cd packages/cli && bun link",
    "version:patch": "npm version patch --workspace racore --no-git-tag-version",
    "version:minor": "npm version minor --workspace racore --no-git-tag-version",
    "version:major": "npm version major --workspace racore --no-git-tag-version"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
