{
  "name": "racore",
  "version": "1.0.0",
  "description": "R'a Core standalone terminal AI coding assistant",
  "module": "src/index.tsx",
  "type": "module",
  "license": "MIT",
  "author": "R'a Core",
  "homepage": "https://www.npmjs.com/package/racore",
  "repository": {
    "type": "git",
    "url": "https://github.com/racorexyz/racore.git"
  },
  "bugs": {
    "url": "https://github.com/racorexyz/racore/issues"
  },
  "keywords": [
    "cli",
    "ai",
    "coding-agent",
    "terminal",
    "openrouter",
    "openai"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "README.md"
  ],
  "bin": {
    "racore": "./bin/racore"
  },
  "scripts": {
    "dev": "bun run --watch src/index.tsx",
    "build": "bun build src/index.tsx --outdir dist --target bun",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.23",
    "@opentui/core": "^0.1.97",
    "@opentui/react": "^0.1.97",
    "ai": "^6.0.184",
    "date-fns": "^4.1.0",
    "open": "^11.0.0",
    "opentui-spinner": "^0.0.6",
    "pretty-ms": "^9.3.0",
    "react": "^19.2.4",
    "react-router": "^7.14.0",
    "zod": "^3.25.76"
  }
}
